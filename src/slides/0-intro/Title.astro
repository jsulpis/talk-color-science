---
import Slide from "../../components/Slide.astro";
import introBackground from "./assets/intro-background.jpg";
import riviera from "./assets/riviera.svg";
---

<Slide data-background-image={introBackground.src} style="top: 0;">
	<div class="content">
		<span class="event">
			<img data-src={riviera.src} alt="RivieraDev Logo" />
			<span class="date">08/07/2025</span>
		</span>
		<div class="title">
			<h1>
				Savez-vous <i>vraiment</i> ce qu'est la <strong>couleur</strong> ?
			</h1>
			<p>Découvrez la science derrière les pixels 🎨</p>
		</div>

		<p class="speaker">
			<span class="name">Julien Sulpis</span>
		</p>
	</div>
</Slide>

<style lang="scss">
	.content {
		height: min(70dvh, 600px);
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		margin-top: -10%;
	}
	p {
		margin: 0;
	}
	h1,
	p {
		text-shadow:
			0 0 2dvh rgba(0 0 0 / 0.5),
			0 0 15dvh black;
	}
	h1 {
		font-size: 5.2rem;
		font-weight: 400;
	}
	.title p {
		font-size: 3.5rem;
	}
	.speaker {
		display: flex;
		flex-direction: column;
		line-height: 1.5;
	}
	.name {
		font-size: 1em;
		font-weight: bold;
	}
	.event {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		font-size: 0.9em;

		img {
			height: 10svh;
			width: auto;
		}
	}
</style>
